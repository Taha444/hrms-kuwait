# إعدادات الواجهة الخلفية (Backend) — انسخ هذا الملف إلى .env واملأ القيم
# ===========================================================================

# مفتاح سري لتوقيع رموز JWT — غيّره في الإنتاج إلى قيمة عشوائية طويلة
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# مدة صلاحية رمز الدخول (دقائق) ورمز التجديد (أيام)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# قاعدة البيانات:
#  - للتطوير المحلي (SQLite): sqlite:///./hrms.db
#  - للإنتاج (PostgreSQL):     postgresql+psycopg2://hrms:hrms@db:5432/hrms
DATABASE_URL=sqlite:///./hrms_app.db

# مجلد تخزين الملفات المرفوعة (مستندات، صور السيلفي)
UPLOAD_DIR=./uploads

# أصول الواجهة المسموح لها (CORS) — افصل بينها بفاصلة
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# كلمة المرور الموحّدة لأول دخول (تُجبر التغيير) — تُستخدم عند إنشاء مستخدم جديد
DEFAULT_USER_PASSWORD=Kuwait@2024

# تفعيل المهام المجدولة (المسح اليومي للمستندات المنتهية)
SCHEDULER_ENABLED=true

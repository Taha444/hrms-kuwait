# إعدادات النشر عبر Docker Compose — انسخ إلى .env
# =====================================================

# قاعدة بيانات PostgreSQL
POSTGRES_USER=hrms
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=hrms

# مفتاح توقيع JWT — استخدم قيمة عشوائية طويلة في الإنتاج
SECRET_KEY=change-this-to-a-long-random-secret

# أصول الواجهة المسموح بها (CORS) — دومين موقعك في الإنتاج
CORS_ORIGINS=http://localhost

# منفذ الواجهة (80 افتراضيًا)
WEB_PORT=80

# انسخ هذا الملف إلى .env وعدّل القيم. لا ترفع .env إلى Git.

# ---- التشغيل ----
HRMS_DEBUG=false
HRMS_HOST=127.0.0.1
HRMS_PORT=5000

# ---- الأمان ----
# في الإنتاج عيّن مفتاحًا ثابتًا قويًا (مثلاً ناتج: python -c "import secrets;print(secrets.token_hex(32))")
HRMS_SECRET_KEY=
HRMS_COOKIE_SECURE=false
HRMS_CSRF=true
HRMS_SESSION_HOURS=8
HRMS_SESSION_IDLE_MINUTES=60
HRMS_MAX_LOGIN_ATTEMPTS=5
HRMS_LOCK_MINUTES=15
HRMS_PASSWORD_MIN_LEN=8
HRMS_RATE_LIMIT_PER_MINUTE=120
HRMS_LOGIN_RATE_LIMIT=10

# ---- رفع الملفات ----
HRMS_MAX_UPLOAD_MB=16

# ---- البريد (إشعارات التنبيهات) ----
HRMS_MAIL_ENABLED=false
HRMS_MAIL_HOST=smtp.gmail.com
HRMS_MAIL_PORT=587
HRMS_MAIL_USERNAME=
HRMS_MAIL_PASSWORD=
HRMS_MAIL_FROM=hrms@example.com
HRMS_MAIL_TLS=true

# ---- الرسائل النصية (SMS) ----
HRMS_SMS_ENABLED=false
HRMS_SMS_PROVIDER=
HRMS_SMS_API_KEY=

# ---- الجدولة (فحص التنبيهات يوميًا) ----
HRMS_SCHEDULER_ENABLED=false
HRMS_ALERTS_SCAN_HOUR=7

# ---- النسخ الاحتياطي ----
HRMS_BACKUP_DIR=
